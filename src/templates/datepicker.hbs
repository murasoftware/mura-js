<div class="{{{inputWrapperClass}}} mura-form-datepicker-container" id="field-{{name}}-container">
  <label for="{{labelForValue}}" data-for="{{name}}">
    {{#if summary}}{{summary}}{{else}}{{label}}{{/if}}
    {{#if isrequired}} <ins>{{formRequiredLabel}}</ins>{{/if}}
  </label>
  {{#if summary}}</br>{{/if}}
  <div class="mura-form-datepicker-inputwrap">
    <input
      id="{{labelForValue}}"
      type="date"
      {{{commonInputAttributes}}}
      data-datepicker="{{name}}"
      value="{{value}}"
      {{#if isrequired}} aria-required="true"{{/if}}
      {{#if placeholder}} placeholder="{{placeholder}}"{{/if}}
      class="mura-datepicker form-control"
      autocomplete="off"
      tabindex="0"
      aria-haspopup="dialog"
    />
  </div>
</div>